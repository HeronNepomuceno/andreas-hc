---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { ShieldCheck, Leaf, Phone, Clock3, Star } from '@lucide/astro';
import { getYelpData } from '../utils/yelp';

const yelp = await getYelpData();

const highlights = [
  yelp ? `${yelp.rating.toFixed(1)} Yelp rating` : 'Yelp-reviewed business',
  'Established in 2018',
  'Business phone: (415) 374-1720'
];
---

<Layout
  title="About Andreas Cleaning Co. | House Cleaning in Daly City and the Bay Area"
  description="Learn how Andreas Cleaning Co. grew from a 2018 local cleaning business into a Bay Area service focused on safety, quality, and reliable deep and regular cleaning."
  yelp={yelp}
>
  <Navbar />
  <main>
    <section class="py-20 bg-background border-b border-surface-alt">
      <div class="max-w-7xl mx-auto px-6">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div data-animate>
            <div class="inline-flex items-center gap-2 bg-surface-alt px-3 py-1.5 rounded-full text-primary font-semibold text-xs uppercase tracking-wider mb-6">
              <Star class="w-4 h-4" />
              Bay Area Cleaning Company
            </div>
            <h1 class="text-4xl md:text-5xl font-bold text-heading mb-6 leading-tight">
              Professional cleaning services built on safety, quality, and consistency.
            </h1>
            <p class="text-lg text-body leading-relaxed mb-8 max-w-2xl">
              Andreas Cleaning Co. was established in 2018 and grew through local outreach, a stronger Yelp presence, and a focus on repeat clients.
            </p>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
              {highlights.map((item) => (
                <div class="flex items-center gap-3 bg-surface rounded-2xl border border-surface-alt px-4 py-3">
                  <span class="w-2.5 h-2.5 rounded-full bg-primary shrink-0"></span>
                  <span class="text-[15px] text-body">{item}</span>
                </div>
              ))}
            </div>
          </div>

          <div class="relative" data-animate>
            <div class="aspect-[4/3] bg-surface rounded-3xl border border-surface-alt shadow-2xl p-8 overflow-hidden">
              <div class="flex items-start justify-between mb-8">
                <div>
                  <p class="text-[11px] font-bold text-muted uppercase tracking-widest mb-1">About the business</p>
                  <h2 class="text-2xl font-bold text-heading">Established in 2018</h2>
                </div>
                <div class="flex items-center gap-1.5 bg-success/10 px-3 py-1 rounded-full">
                  <span class="w-1.5 h-1.5 bg-success rounded-full animate-pulse"></span>
                  <span class="text-success text-[11px] font-bold uppercase tracking-wide">Serving clients</span>
                </div>
              </div>

              <div class="grid grid-cols-2 gap-4 mb-6">
                <div class="rounded-2xl bg-surface-alt p-4">
                  <Phone class="w-5 h-5 text-primary mb-3" />
                  <p class="text-[11px] uppercase tracking-wider text-muted mb-1">Phone</p>
                  <p class="text-[15px] font-semibold text-heading">(415) 374-1720</p>
                </div>
                <div class="rounded-2xl bg-surface-alt p-4">
                  <Clock3 class="w-5 h-5 text-primary mb-3" />
                  <p class="text-[11px] uppercase tracking-wider text-muted mb-1">Since</p>
                  <p class="text-[15px] font-semibold text-heading">2018</p>
                </div>
              </div>

              <div class="rounded-2xl border border-surface-alt p-5 bg-background">
                <p class="text-sm text-muted uppercase tracking-wider mb-3">Current focus</p>
                <p class="text-[15px] text-body leading-relaxed">
                  Serving homes and repeat clients across the Bay Area with a cleaner, more reliable service experience.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="py-20 bg-background">
      <div class="max-w-7xl mx-auto px-6">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
          <div data-animate>
            <div class="inline-flex items-center gap-2 bg-surface-alt px-3 py-1.5 rounded-full text-primary font-semibold text-xs uppercase tracking-wider mb-6">
              <Clock3 class="w-4 h-4" />
              Business History
            </div>
            <h2 class="text-3xl font-bold text-heading mb-6">Built from 2018 with steady, practical growth.</h2>
            <div class="space-y-6 text-lg text-body leading-relaxed max-w-2xl">
              <p>
                The company started with local marketing and business cards in San Francisco, then grew by building a clearer presence on Yelp.
              </p>
              <p>
                That approach helped the business move from one-time jobs to recurring clients, and it is still how the company thinks about growth today.
              </p>
            </div>
          </div>

          <div class="rounded-2xl bg-surface border border-surface-alt p-6" data-animate>
            <p class="text-[11px] uppercase tracking-widest text-muted mb-2">What the business emphasizes</p>
            <p class="text-[15px] text-body leading-relaxed">
              Eco-friendly products, careful surface cleaning, and finishing details like towel origami in bedrooms and bathrooms.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="py-20 bg-surface-alt">
      <div class="max-w-7xl mx-auto px-6">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div class="relative" data-animate>
            <div class="rounded-3xl bg-surface border border-[#E2E8F0] shadow-xl p-8">
              <p class="text-[11px] uppercase tracking-widest text-muted mb-4">Business Owner</p>
              <div class="flex items-center gap-4 mb-4">
                <img
                  src="/andreas.jpg"
                  alt="Andreas"
                  class="w-14 h-14 rounded-full object-cover border-2 border-surface-alt shadow-sm"
                />
                <h2 class="text-3xl font-bold text-heading">Andréa S.</h2>
              </div>
              <p class="text-[15px] text-body leading-relaxed mb-5">
                Andréa started the company because he wanted to provide clients with a comfortable, clean environment and to create work that feels
                personal rather than transactional.
              </p>
              <p class="text-[15px] text-body leading-relaxed">
                What drives the business is the reaction after a job is finished: seeing the client relax when the space looks and feels better.
              </p>
            </div>
          </div>
          <div data-animate class="space-y-4">
            <div class="inline-flex items-center gap-2 bg-surface-alt px-3 py-1.5 rounded-full text-primary font-semibold text-xs uppercase tracking-wider">
              <Leaf class="w-4 h-4" />
              Service Notes
            </div>
            <p class="text-[15px] text-body leading-relaxed max-w-xl">
              Eco-friendly products are used as requested, and towel origami is used as a finishing touch in bedrooms and bathrooms.
            </p>
            <a
              href="/contact"
              class="inline-flex items-center justify-center bg-primary text-white px-6 py-3 rounded-full font-semibold hover:bg-primary-dark transition-all"
            >
              Schedule an Appointment
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
