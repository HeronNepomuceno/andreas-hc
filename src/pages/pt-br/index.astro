---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Hero from '../../components/Hero.astro';
import TrustBar from '../../components/TrustBar.astro';
import Services from '../../components/Services.astro';
import HowItWorks from '../../components/HowItWorks.astro';
import Testimonials from '../../components/Testimonials.astro';
import FAQ from '../../components/FAQ.astro';
import Footer from '../../components/Footer.astro';
import LocationHours from '../../components/LocationHours.astro';
import { getYelpData } from '../../utils/yelp';
import { getLocalizedPath } from '../../i18n/routing';
import { getSiteCopy } from '../../i18n/content';

const locale = 'pt-br';
const copy = getSiteCopy(locale);
const yelp = await getYelpData();
---

<Layout
  title="Serviços de limpeza residencial em San Francisco | Andreas Cleaning Co."
  description="Serviços profissionais e segurados de limpeza residencial em San Francisco. Equipe com verificação de antecedentes, produtos ecológicos e orçamento rápido em 60 segundos."
  yelp={yelp}
>
  <Navbar locale={locale} pagePath="" copy={copy.nav} />
  <main>
    <Hero locale={locale} copy={copy.hero} yelp={yelp} />
    <TrustBar copy={copy.trustBar} yelp={yelp} />
    <Services locale={locale} copy={copy.services} />
    <HowItWorks locale={locale} copy={copy.howItWorks} />
    <Testimonials locale={locale} copy={copy.testimonials} />
    <LocationHours locale={locale} copy={copy.locationHours} />
    <section id="faq" class="py-20 bg-surface-alt">
      <div class="max-w-3xl mx-auto px-6">
        <div class="text-center mb-16" data-animate>
          <h2 class="text-3xl md:text-4xl font-bold text-heading mb-4">{copy.faq.heading}</h2>
          <p class="text-lg text-muted">
            {copy.faq.contactPrompt} <a href={getLocalizedPath(locale, 'contact')} class="text-primary font-semibold hover:underline">{copy.faq.contactLink}</a>.
          </p>
        </div>
        <div data-animate>
          <FAQ items={copy.faq.items} />
        </div>
      </div>
    </section>
  </main>
  <Footer locale={locale} copy={copy.footer} />
</Layout>
