---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { Phone, Mail, MapPin, Clock, ArrowRight } from '@lucide/astro';
import { getYelpData } from '../../utils/yelp';
import { getSiteCopy } from '../../i18n/content';

const locale = 'pt-br';
const copy = getSiteCopy(locale);
const yelp = await getYelpData();
---

<Layout
  title={copy.contact.seoTitle}
  description={copy.contact.seoDescription}
  yelp={yelp}
>
  <Navbar locale={locale} pagePath="contact" copy={copy.nav} />
  <main class="py-12 md:py-20 bg-background">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 items-start">
        <div class="lg:col-span-1" data-animate>
          <h1 class="text-4xl font-bold text-heading mb-6 leading-tight">{copy.contact.heading}</h1>
          <p class="text-lg text-body mb-10 leading-relaxed">
            {copy.contact.intro}
          </p>

          <div class="space-y-8">
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 bg-primary/5 rounded-full flex items-center justify-center shrink-0">
                <Phone class="w-5 h-5 text-primary" />
              </div>
              <div class="flex flex-col">
                <span class="text-sm font-bold text-heading uppercase tracking-wider mb-1">{copy.contact.callUs}</span>
                <a href="tel:4155550100" class="text-lg text-body hover:text-primary transition-colors">(415) 374-1720</a>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-10 h-10 bg-primary/5 rounded-full flex items-center justify-center shrink-0">
                <Mail class="w-5 h-5 text-primary" />
              </div>
              <div class="flex flex-col">
                <span class="text-sm font-bold text-heading uppercase tracking-wider mb-1">{copy.contact.emailUs}</span>
                <a href="mailto:andreasperfectcleaning@gmail.com" class="text-lg text-body hover:text-primary transition-colors">andreasperfectcleaning@gmail.com</a>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-10 h-10 bg-primary/5 rounded-full flex items-center justify-center shrink-0">
                <MapPin class="w-5 h-5 text-primary" />
              </div>
              <div class="flex flex-col">
                <span class="text-sm font-bold text-heading uppercase tracking-wider mb-1">{copy.contact.location}</span>
                <span class="text-lg text-body">Atendemos todos os bairros de San Francisco</span>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-10 h-10 bg-primary/5 rounded-full flex items-center justify-center shrink-0">
                <Clock class="w-5 h-5 text-primary" />
              </div>
              <div class="flex flex-col">
                <span class="text-sm font-bold text-heading uppercase tracking-wider mb-1">{copy.contact.hours}</span>
                <span class="text-lg text-body">Seg–Sáb: 7:00 – 19:00</span>
              </div>
            </div>
          </div>

          <div class="mt-12 p-6 bg-surface-alt rounded-2xl border border-[#E2E8F0]">
            <p class="text-sm text-muted leading-relaxed">
              <span class="font-bold text-heading">🔒 {copy.contact.privacyLabel}:</span> {copy.contact.privacy}
            </p>
          </div>
        </div>

        <div class="lg:col-span-2" data-animate>
          <div class="bg-surface p-8 md:p-12 rounded-[32px] border border-[#E2E8F0] shadow-xl">
            <form action="https://formsubmit.co/andreasperfectcleaning@gmail.com" method="POST" class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <!-- Configuração do FormSubmit -->
              <input type="hidden" name="_subject" value="Novo Formulário de Contato - Andreas Perfect Cleaning">
              <input type="hidden" name="_honey" style="display:none">
              <input type="hidden" name="_template" value="table">

              <div class="flex flex-col">
                <label for="full_name" class="text-sm font-semibold text-heading mb-2">{copy.contact.fullName}</label>
                <input 
                  type="text" 
                  id="full_name" 
                  name="full_name" 
                  required 
                  placeholder={copy.contact.namePlaceholder}
                  class="bg-background border border-[#CBD5E1] rounded-xl px-4 py-3 text-[15px] focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all placeholder:text-muted/50"
                />
              </div>

              <div class="flex flex-col">
                <label for="email" class="text-sm font-semibold text-heading mb-2">{copy.contact.emailAddress}</label>
                <input 
                  type="email" 
                  id="email" 
                  name="email" 
                  required 
                  placeholder={copy.contact.emailPlaceholder}
                  class="bg-background border border-[#CBD5E1] rounded-xl px-4 py-3 text-[15px] focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all placeholder:text-muted/50"
                />
              </div>

              <div class="flex flex-col">
                <label for="phone" class="text-sm font-semibold text-heading mb-2">{copy.contact.phoneNumber}</label>
                <input 
                  type="tel" 
                  id="phone" 
                  name="phone" 
                  placeholder={copy.contact.phonePlaceholder}
                  class="bg-background border border-[#CBD5E1] rounded-xl px-4 py-3 text-[15px] focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all placeholder:text-muted/50"
                />
              </div>

              <div class="flex flex-col">
                <label for="service_type" class="text-sm font-semibold text-heading mb-2">{copy.contact.serviceType}</label>
                <select 
                  id="service_type" 
                  name="service_type" 
                  required
                  class="bg-background border border-[#CBD5E1] rounded-xl px-4 py-3 text-[15px] focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all appearance-none cursor-pointer"
                >
                  <option value="" disabled selected>{copy.contact.servicePlaceholder}</option>
                  {copy.contact.services.map(s => <option value={s}>{s}</option>)}
                </select>
              </div>

              <div class="flex flex-col">
                <label for="property_size" class="text-sm font-semibold text-heading mb-2">{copy.contact.propertySize}</label>
                <select 
                  id="property_size" 
                  name="property_size" 
                  required
                  class="bg-background border border-[#CBD5E1] rounded-xl px-4 py-3 text-[15px] focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all appearance-none cursor-pointer"
                >
                  <option value="" disabled selected>{copy.contact.sizePlaceholder}</option>
                  {copy.contact.sizes.map(s => <option value={s}>{s}</option>)}
                </select>
              </div>

              <div class="flex flex-col">
                <label for="date" class="text-sm font-semibold text-heading mb-2">{copy.contact.preferredDate}</label>
                <input 
                  type="date" 
                  id="date" 
                  name="date"
                  class="bg-background border border-[#CBD5E1] rounded-xl px-4 py-3 text-[15px] focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all cursor-pointer"
                />
              </div>

              <div class="flex flex-col md:col-span-2">
                <label for="preferred_time" class="text-sm font-semibold text-heading mb-2">{copy.contact.preferredTime}</label>
                <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
                  {copy.contact.times.map(t => (
                    <label class="flex items-center gap-3 bg-background border border-[#CBD5E1] rounded-xl px-4 py-3 cursor-pointer hover:border-primary transition-all has-[:checked]:border-primary has-[:checked]:bg-primary/5">
                      <input type="radio" name="preferred_time" value={t} class="w-4 h-4 text-primary focus:ring-primary border-[#CBD5E1]" />
                      <span class="text-[13px] font-medium text-body">{t}</span>
                    </label>
                  ))}
                </div>
              </div>

              <div class="flex flex-col md:col-span-2">
                <label for="notes" class="text-sm font-semibold text-heading mb-2">{copy.contact.additionalNotes}</label>
                <textarea 
                  id="notes" 
                  name="notes" 
                  rows="4" 
                  placeholder={copy.contact.notePlaceholder}
                  class="bg-background border border-[#CBD5E1] rounded-xl px-4 py-3 text-[15px] focus:border-primary focus:ring-4 focus:ring-primary/5 outline-none transition-all placeholder:text-muted/50 resize-none"
                ></textarea>
              </div>

              <div class="md:col-span-2 mt-4">
                <button 
                  type="submit" 
                  class="w-full bg-primary text-white py-4 rounded-full font-bold text-lg hover:bg-primary-dark transition-all shadow-xl shadow-primary/20 flex items-center justify-center gap-2 group active:scale-[0.98]"
                >
                  {copy.contact.submit} <ArrowRight class="w-5 h-5 group-hover:translate-x-1 transition-transform" />
                </button>
                <p class="text-center text-[13px] text-muted mt-6">
                  {copy.contact.submitNote}
                </p>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>
  </main>
  <Footer locale={locale} copy={copy.footer} />
</Layout>
