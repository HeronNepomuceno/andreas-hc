---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import CTABanner from '../components/CTABanner.astro';
import { Sparkles, Layers, PackageOpen, Building2, HardHat, BedDouble, Check, Clock } from '@lucide/astro';

const serviceDetails = [
  {
    id: 'standard',
    icon: Sparkles,
    title: 'Standard Cleaning',
    description: 'Regular scheduled cleanings to keep your home consistently fresh and tidy. Ideal for homeowners wanting consistent upkeep without the hassle.',
    included: [
      'Dusting all accessible surfaces',
      'Vacuuming and mopping all floors',
      'Cleaning and sanitizing bathrooms',
      'Wiping down kitchen exteriors',
      'Emptying trash and recycling',
      'Making beds (linen change on request)'
    ],
    duration: '2-4 Hours',
    bg: 'bg-background'
  },
  {
    id: 'deep',
    icon: Layers,
    title: 'Deep Cleaning',
    description: 'A thorough top-to-bottom clean, perfect for seasonal resets or first-time bookings. We go beyond the surface to tackle hidden grime.',
    included: [
      'Everything in Standard Cleaning',
      'Detailed baseboard wiping',
      'Interior window cleaning (reachable)',
      'Cabinet fronts and handles detailed',
      'Dusting ceiling fans and light fixtures',
      'Deep scrubbing of tile grout'
    ],
    duration: '4-7 Hours',
    bg: 'bg-surface-alt'
  },
  {
    id: 'move',
    icon: PackageOpen,
    title: 'Move In / Move Out',
    description: 'Leave your old place spotless or arrive to a perfectly clean new home. We ensure every inch is ready for the next chapter.',
    included: [
      'Deep cleaning of all rooms',
      'Inside cabinets and drawers cleaned',
      'Inside oven and refrigerator cleaned',
      'Closet shelves and floors wiped',
      'Detailed door frame and trim cleaning',
      'Thorough wall spotting (as needed)'
    ],
    duration: '5-9 Hours',
    bg: 'bg-background'
  },
  {
    id: 'office',
    icon: Building2,
    title: 'Office & Commercial',
    description: 'Professional workspace cleaning that keeps your team productive and your clients impressed. Flexible scheduling to avoid business disruption.',
    included: [
      'Desk and workstation sanitizing',
      'Breakroom and kitchenette cleaning',
      'Public area and lobby maintenance',
      'Restroom deep cleaning',
      'High-touch point disinfection',
      'Trash management and floor care'
    ],
    duration: 'Custom Based on Size',
    bg: 'bg-surface-alt'
  },
  {
    id: 'construction',
    icon: HardHat,
    title: 'Post-Construction',
    description: 'We remove fine dust, debris, and residue so your newly built or renovated space is safe and move-in ready.',
    included: [
      'Fine dust removal from all surfaces',
      'Window track and frame cleaning',
      'Removal of paint and adhesive spots',
      'Deep floor vacuuming and scrubbing',
      'HVAC vent surface dusting',
      'Detailed cabinet and fixture cleaning'
    ],
    duration: '6-12 Hours',
    bg: 'bg-background'
  },
  {
    id: 'airbnb',
    icon: BedDouble,
    title: 'Airbnb & Vacation Rental',
    description: 'Fast, reliable turnover cleaning between guests to keep your reviews glowing. We handle the details so you can focus on hosting.',
    included: [
      'Complete room turnover and staging',
      'Linen laundering and bed making',
      'Restocking guest essentials',
      'Detail check for guest readiness',
      'Inventory reporting',
      'Damage and maintenance reporting'
    ],
    duration: '2-4 Hours',
    bg: 'bg-surface-alt'
  }
];
---

<Layout
  title="House Cleaning Services in San Francisco | Andreas Cleaning Co."
  description="Explore all our cleaning services — standard, deep clean, move in/out, office, post-construction, and Airbnb turnover cleaning in San Francisco."
>
  <Navbar />
  <main>
    <!-- Hero Section -->
    <section class="py-20 bg-background border-b border-surface-alt">
      <div class="max-w-7xl mx-auto px-6 text-center" data-animate>
        <h1 class="text-4xl md:text-5xl font-bold text-heading mb-6">Our Cleaning Services</h1>
        <p class="text-xl text-body max-w-3xl mx-auto leading-relaxed">
          From regular upkeep to specialized deep cleans, we cover every corner of your home or office with the same attention to detail.
        </p>
      </div>
    </section>

    <!-- Detailed Services -->
    {serviceDetails.map((service, index) => (
      <section class={`py-20 ${service.bg} overflow-hidden`}>
        <div class="max-w-7xl mx-auto px-6">
          <div class={`grid grid-cols-1 lg:grid-cols-2 gap-12 items-center ${index % 2 !== 0 ? 'lg:flex-row-reverse' : ''}`}>
            <div data-animate class={index % 2 !== 0 ? 'lg:order-2' : ''}>
              <div class="w-16 h-16 bg-primary/10 rounded-2xl flex items-center justify-center mb-6">
                <service.icon class="w-8 h-8 text-primary" />
              </div>
              <h2 class="text-3xl font-bold text-heading mb-4">{service.title}</h2>
              <p class="text-lg text-body mb-8 leading-relaxed">
                {service.description}
              </p>
              
              <div class="bg-surface p-8 rounded-2xl border border-surface-alt shadow-sm">
                <h3 class="text-sm font-bold text-heading uppercase tracking-widest mb-6">What's Included</h3>
                <ul class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                  {service.included.map(item => (
                    <li class="flex items-start gap-3 text-[15px] text-body">
                      <Check class="w-5 h-5 text-secondary shrink-0 mt-0.5" />
                      {item}
                    </li>
                  ))}
                </ul>
              </div>

              <div class="mt-8 flex flex-wrap items-center gap-6">
                <div class="flex items-center gap-2 text-muted">
                  <Clock class="w-5 h-5" />
                  <span class="text-sm font-medium">Typical Duration: {service.duration}</span>
                </div>
                <a 
                  href="/contact" 
                  class="bg-primary text-white px-6 py-3 rounded-full font-bold hover:bg-primary-dark transition-colors shadow-lg shadow-primary/10"
                >
                  Request This Service
                </a>
              </div>
            </div>

            <div class={`relative ${index % 2 !== 0 ? 'lg:order-1' : ''}`} data-animate>
               <!-- Placeholder for Service Illustration -->
               <div class="aspect-square bg-surface rounded-[40px] border border-surface-alt shadow-xl flex items-center justify-center p-12 overflow-hidden group">
                  <service.icon class="w-32 h-32 text-primary/20 group-hover:scale-110 transition-transform duration-500" />
                  <div class="absolute inset-0 bg-gradient-to-br from-primary/5 to-transparent opacity-50"></div>
                  <!-- Abstract Shapes -->
                  <div class="absolute -top-10 -right-10 w-40 h-40 bg-secondary/5 rounded-full blur-2xl"></div>
                  <div class="absolute -bottom-10 -left-10 w-40 h-40 bg-accent/5 rounded-full blur-2xl"></div>
               </div>
            </div>
          </div>
        </div>
      </section>
    ))}

    <CTABanner />
  </main>
  <Footer />
</Layout>
