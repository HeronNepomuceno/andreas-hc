---
import { Sparkles, Layers, PackageOpen, Building2, HardHat, BedDouble, ArrowRight } from '@lucide/astro';
import { getLocalizedPath, type Locale } from '../i18n/routing';
import type { SiteCopy } from '../i18n/content';

interface Props {
  locale: Locale;
  copy: SiteCopy['services'];
}

const { locale, copy } = Astro.props;

const services = [
  {
    icon: Layers,
    title: copy.services[0].title,
    description: copy.services[0].description
  },
  {
    icon: PackageOpen,
    title: copy.services[1].title,
    description: copy.services[1].description
  },
  {
    icon: Sparkles,
    title: copy.services[2].title,
    description: copy.services[2].description
  },
  {
    icon: Building2,
    title: copy.services[3].title,
    description: copy.services[3].description
  },
  {
    icon: BedDouble,
    title: copy.services[4].title,
    description: copy.services[4].description
  },
  {
    icon: HardHat,
    title: copy.services[5].title,
    description: copy.services[5].description
  }
];
---

<section id="services" class="py-20 bg-background">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center max-w-2xl mx-auto mb-16" data-animate>
      <h2 class="text-3xl md:text-4xl font-bold text-heading mb-4">{copy.heading}</h2>
      <p class="text-lg text-muted">{copy.description}</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {services.map(service => (
        <div 
          class="bg-surface p-8 rounded-2xl border border-[#E2E8F0] hover:shadow-xl hover:-translate-y-2 transition-all duration-300 group"
          data-animate
        >
          <div class="w-14 h-14 bg-primary/5 rounded-2xl flex items-center justify-center mb-6 group-hover:bg-primary/10 transition-colors">
            <service.icon class="w-7 h-7 text-primary" />
          </div>
          <h3 class="text-xl font-bold text-heading mb-3">{service.title}</h3>
          <p class="text-[15px] text-body leading-relaxed mb-6">{service.description}</p>
          <a 
            href={`${getLocalizedPath(locale)}#services`} 
            class="inline-flex items-center gap-2 text-primary font-semibold hover:gap-3 transition-all"
          >
            {copy.learnMore} <ArrowRight class="w-4 h-4" />
          </a>
        </div>
      ))}
    </div>
  </div>
</section>
