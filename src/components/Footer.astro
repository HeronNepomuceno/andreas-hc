---
import { Sparkles, Camera, Users, MapPin, Phone, Mail, Clock } from '@lucide/astro';
---

<footer class="bg-heading text-[#94A3B8] pt-16 pb-8">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-8">
      <!-- Col 1 — Brand -->
      <div class="space-y-6">
        <div class="flex items-center gap-2 text-white">
          <Sparkles class="w-6 h-6" />
          <span class="text-xl font-semibold">Andreas Cleaning Co.</span>
        </div>
        <p class="text-sm leading-relaxed">
          Professional house cleaning services in San Francisco, CA. Reliable, insured, and background-checked team.
        </p>
        <div class="flex items-center gap-4">
          <a href="#" class="text-white hover:text-primary transition-colors" aria-label="Instagram">
            <Camera class="w-5 h-5" />
          </a>
          <a href="#" class="text-white hover:text-primary transition-colors" aria-label="Facebook">
            <Users class="w-5 h-5" />
          </a>
        </div>
      </div>

      <!-- Col 2 — Services -->
      <div>
        <h3 class="text-white text-sm font-semibold tracking-widest uppercase mb-6">Services</h3>
        <ul class="space-y-4 text-sm">
          <li><a href="/services" class="hover:text-white transition-colors">Standard Cleaning</a></li>
          <li><a href="/services" class="hover:text-white transition-colors">Deep Cleaning</a></li>
          <li><a href="/services" class="hover:text-white transition-colors">Move In/Out</a></li>
          <li><a href="/services" class="hover:text-white transition-colors">Office Cleaning</a></li>
          <li><a href="/services" class="hover:text-white transition-colors">Post-Construction</a></li>
          <li><a href="/services" class="hover:text-white transition-colors">Airbnb Cleaning</a></li>
        </ul>
      </div>

      <!-- Col 3 — Company -->
      <div>
        <h3 class="text-white text-sm font-semibold tracking-widest uppercase mb-6">Company</h3>
        <ul class="space-y-4 text-sm">
          <li><a href="/about" class="hover:text-white transition-colors">About Us</a></li>
          <li><a href="/faq" class="hover:text-white transition-colors">FAQ</a></li>
          <li><a href="/contact" class="hover:text-white transition-colors">Contact</a></li>
          <li><a href="/contact" class="hover:text-white transition-colors">Get a Free Quote</a></li>
        </ul>
      </div>

      <!-- Col 4 — Contact -->
      <div>
        <h3 class="text-white text-sm font-semibold tracking-widest uppercase mb-6">Contact</h3>
        <ul class="space-y-4 text-sm">
          <li class="flex items-start gap-3">
            <MapPin class="w-5 h-5 shrink-0" />
            <span>San Francisco, CA 94105</span>
          </li>
          <li class="flex items-center gap-3">
            <Phone class="w-5 h-5 shrink-0" />
            <span>(415) 555-0100</span>
          </li>
          <li class="flex items-center gap-3">
            <Mail class="w-5 h-5 shrink-0" />
            <span>hello@andreascleaning.com</span>
          </li>
          <li class="flex items-start gap-3">
            <Clock class="w-5 h-5 shrink-0" />
            <span>Mon–Sat: 7:00 AM – 7:00 PM</span>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 pt-8 border-t border-[#1E293B] flex flex-col md:flex-row justify-between items-center gap-4 text-[13px] text-[#64748B]">
      <p>© 2025 Andreas Cleaning Co. All rights reserved.</p>
      <p>Licensed, Bonded & Insured in California</p>
    </div>
  </div>
</footer>
