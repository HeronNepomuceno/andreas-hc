---
import { Sparkles, Camera, Users, MapPin, Phone, Mail, Clock } from '@lucide/astro';
import { getLocalizedPath, type Locale } from '../i18n/routing';
import type { SiteCopy } from '../i18n/content';

interface Props {
  locale: Locale;
  brandName: string;
  copy: SiteCopy['footer'];
}

const { locale, brandName, copy } = Astro.props;

const localizedFaq = `${getLocalizedPath(locale)}#faq`;
const companyLinks = copy.company.map((item) => ({
  label: item.label,
  href: item.href === '#faq' ? localizedFaq : getLocalizedPath(locale, item.href),
}));
---

<footer class="bg-heading text-[#94A3B8] pt-16 pb-8">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-8">
      <!-- Col 1 — Brand -->
      <div class="space-y-6">
        <div class="flex items-center gap-2 text-white">
          <Sparkles class="w-6 h-6" />
          <span class="text-xl font-semibold">{brandName}</span>
        </div>
        <p class="text-sm leading-relaxed">
          {copy.description}
        </p>
        <div class="flex items-center gap-4">
          <a href="#" class="text-white hover:text-primary transition-colors" aria-label={copy.social.instagram}>
            <Camera class="w-5 h-5" />
          </a>
          <a href="#" class="text-white hover:text-primary transition-colors" aria-label={copy.social.facebook}>
            <Users class="w-5 h-5" />
          </a>
        </div>
      </div>

      <!-- Col 2 — Services -->
      <div>
        <h3 class="text-white text-sm font-semibold tracking-widest uppercase mb-6">{copy.servicesTitle}</h3>
        <ul class="space-y-4 text-sm">
          {copy.services.map((item) => (
            <li><a href="#services" class="hover:text-white transition-colors">{item}</a></li>
          ))}
        </ul>
      </div>

      <!-- Col 3 — Company -->
      <div>
        <h3 class="text-white text-sm font-semibold tracking-widest uppercase mb-6">{copy.companyTitle}</h3>
        <ul class="space-y-4 text-sm">
          {companyLinks.map((link) => (
            <li><a href={link.href} class="hover:text-white transition-colors">{link.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Col 4 — Contact -->
      <div>
        <h3 class="text-white text-sm font-semibold tracking-widest uppercase mb-6">{copy.contactTitle}</h3>
        <ul class="space-y-4 text-sm">
          <li class="flex items-start gap-3">
            <MapPin class="w-5 h-5 shrink-0" />
            <span>{copy.contact.address}</span>
          </li>
          <li class="flex items-center gap-3">
            <Phone class="w-5 h-5 shrink-0" />
            <span>{copy.contact.phone}</span>
          </li>
          <li class="flex items-center gap-3">
            <Mail class="w-5 h-5 shrink-0" />
            <span>{copy.contact.email}</span>
          </li>
          <li class="flex items-start gap-3">
            <Clock class="w-5 h-5 shrink-0" />
            <span>{copy.contact.hours}</span>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 pt-8 border-t border-[#1E293B] flex flex-col md:flex-row justify-between items-center gap-4 text-[13px] text-[#64748B]">
      <p>© 2025 {brandName} {copy.rights}</p>
      <p>{copy.license}</p>
    </div>
  </div>
</footer>
