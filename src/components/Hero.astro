---
import { Sparkles } from '@lucide/astro';
import type { YelpBusinessInfo } from '../utils/yelp';
import { getLocalizedPath, type Locale } from '../i18n/routing';
import type { SiteCopy } from '../i18n/content';

interface Props {
  locale: Locale;
  copy: SiteCopy['hero'];
  yelp: YelpBusinessInfo | null;
}

const { locale, copy, yelp } = Astro.props;
const yelpUrl = yelp?.url || 'https://www.yelp.com/biz/andreas-perfect-cleaning-daly-city';
const reviewsCount = yelp ? copy.reviewsCountLabel(yelp.reviewCount, locale) : copy.reviewsFallback;
---

<section class="min-h-[calc(100vh-72px)] bg-background flex items-center py-12 md:py-20 overflow-hidden">
  <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
    
    <!-- Left column — copy -->
    <div data-animate>
      <div class="inline-flex items-center gap-2 bg-surface-alt px-3 py-1.5 rounded-full text-primary font-semibold text-xs uppercase tracking-wider mb-6">
        <Sparkles class="w-4 h-4" />
        {copy.badge}
      </div>
      <h1 class="text-4xl md:text-5xl lg:text-[48px] font-bold text-heading leading-[1.15] mb-6">
        {copy.title}
      </h1>
      <p class="text-lg md:text-xl text-body max-w-xl mb-10 leading-relaxed">
        {copy.description}
      </p>
      
      <div class="flex flex-col sm:flex-row gap-4 mb-10">
        <a 
          href={getLocalizedPath(locale, 'contact')} 
          class="bg-primary text-white px-8 py-4 rounded-full font-semibold text-center hover:bg-primary-dark transition-all hover:scale-105 shadow-lg shadow-primary/20"
        >
          {copy.primaryCta}
        </a>
        <a 
          href="#services" 
          class="border-2 border-primary text-primary px-8 py-4 rounded-full font-semibold text-center hover:bg-primary hover:text-white transition-all"
        >
          {copy.secondaryCta}
        </a>
      </div>
    </div>

    <!-- Right column — illustration -->
    <div class="relative flex justify-center lg:justify-end" data-animate>
      <!-- Background decoration -->
      <div class="absolute -top-20 -right-20 w-64 h-64 bg-primary/5 rounded-full blur-3xl"></div>
      <div class="absolute -bottom-20 -left-20 w-64 h-64 bg-secondary/5 rounded-full blur-3xl"></div>

      <!-- Illustration Card -->
      <div class="relative bg-surface p-8 rounded-[32px] border border-surface-alt shadow-2xl max-w-[400px] w-full transform lg:rotate-2 hover:rotate-0 transition-transform duration-500">
        <!-- ZONA 1: hdr com badge de status -->
        <div class="flex items-center justify-between mb-8">
          <span class="text-[11px] font-bold text-muted uppercase tracking-widest">
            {copy.location}
          </span>
          <div class="flex items-center gap-1.5 bg-success/10 px-3 py-1 rounded-full">
            <span class="w-1.5 h-1.5 bg-success rounded-full animate-pulse"></span>
            <span class="text-success text-[11px] font-bold uppercase tracking-wide">{copy.status}</span>
          </div>
        </div>

        <!-- ZONA 2: Logo centralizada — elemento principal -->
        <div class="flex flex-col items-center justify-center py-8 mb-8 border-y border-surface-alt">
          <img src="/main-logo.png" alt={copy.logoAlt} class="w-full max-w-[320px] h-auto object-contain " />
          <p class="text-muted text-[13px] text-center mt-4 font-medium leading-snug">
            {copy.subtitle}
          </p>
        </div>

        <!-- ZONA 3: Yelp CTA -->
        <a
          href={yelpUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="group flex flex-col gap-4 bg-surface-alt/70 hover:bg-surface border border-surface-alt rounded-2xl p-5 transition-all duration-300 hover:shadow-md hover:border-primary/20"
          aria-label={copy.ariaLabel}
        >
          <!-- Yelp logo + "Read our reviews" -->
          <div class="flex items-center justify-between">
            <span class="text-[17px] font-semibold tracking-tight text-heading">{copy.yelpLabel}</span>

            <!-- Arrow indicator -->
            <span class="w-8 h-8 rounded-full bg-surface border border-surface-alt flex items-center justify-center text-primary group-hover:bg-primary group-hover:border-primary group-hover:text-white transition-all duration-300 shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M7 17L17 7M17 7H7M17 7v10"/>
              </svg>
            </span>
          </div>

          <!-- Stars + rating -->
          <div class="flex items-center gap-2">
            <!-- 5 red stars -->
            <div class="flex items-center gap-0.5">
              {[...Array(5)].map((_, i) => (
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class={`w-4 h-4 ${i < 4 ? 'text-primary' : 'text-primary/70'}`}
                  viewBox="0 0 24 24"
                  fill={i < 5 ? 'currentColor' : 'none'}
                  stroke="currentColor"
                  stroke-width="1"
                >
                  <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                </svg>
              ))}
            </div>
            {yelp ? (
              <>
                <span class="text-[15px] font-bold text-heading">{yelp.rating.toFixed(1)}</span>
                <span class="text-[13px] text-muted">· {reviewsCount}</span>
              </>
            ) : (
              <span class="text-[13px] text-muted">{copy.reviewsFallback}</span>
            )}
          </div>

          <!-- CTA text -->
          <p class="text-[13px] text-body font-semibold leading-snug group-hover:text-primary transition-colors">
            {copy.reviewsCta} →
          </p>
        </a>
      </div>
    </div>

  </div>
</section>
