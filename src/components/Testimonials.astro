---
import { Star } from '@lucide/astro';
import type { Locale } from '../i18n/routing';
import type { SiteCopy } from '../i18n/content';

interface Props {
  locale: Locale;
  copy: SiteCopy['testimonials'];
}

const { copy } = Astro.props;

const testimonials = copy.testimonials;
---

<section class="py-20 bg-background">
  <div class="max-w-7xl mx-auto px-6">
    <div class="text-center max-w-2xl mx-auto mb-16" data-animate>
      <h2 class="text-3xl md:text-4xl font-bold text-heading mb-4">{copy.heading}</h2>
      <p class="text-lg text-muted">{copy.description}</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {testimonials.map(item => (
        <div 
          class="bg-surface p-8 rounded-2xl border border-[#E2E8F0] shadow-sm hover:shadow-md transition-shadow"
          data-animate
        >
          <div class="flex gap-1 mb-6">
            {[...Array(5)].map(() => (
              <Star class="w-5 h-5 fill-warning text-warning" />
            ))}
          </div>
          <p class="text-[15px] text-body italic leading-relaxed mb-8">
            "{item.text}"
          </p>
          <div class="flex items-center gap-4">
            <div class={`w-11 h-11 ${item.color} text-white rounded-full flex items-center justify-center font-bold text-sm shadow-sm`}>
              {item.initials}
            </div>
            <div class="flex flex-col">
              <span class="text-[15px] font-bold text-heading leading-tight">{item.name}</span>
              <span class="text-[13px] text-muted">{item.neighborhood}</span>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
